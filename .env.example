# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=rinkel-auditor
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Supabase / PostgreSQL ────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/rinkel

# ── Google Drive ─────────────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json
GOOGLE_DRIVE_SHARE_WITH=user1@company.nl,user2@company.nl

# ── Audio Processing ─────────────────────────────────────────────────────────
AUDIO_TEMP_DIR=/tmp/rinkel-audio
AUDIO_DOWNLOAD_TIMEOUT=120
AUDIO_MAX_FILE_SIZE_MB=500
AUDIO_RETRY_MAX_ATTEMPTS=3
AUDIO_RETRY_BASE_DELAY=2.0
AUDIO_CLEANUP_AFTER_UPLOAD=true

# ── Whisper / OpenAI ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=nl
WHISPER_RESPONSE_FORMAT=verbose_json
WHISPER_TEMPERATURE=0.0
WHISPER_MAX_FILE_SIZE_MB=25
WHISPER_CHUNK_DURATION_MINUTES=10
WHISPER_RETRY_MAX_ATTEMPTS=3
WHISPER_RETRY_BASE_DELAY=3.0
WHISPER_COST_PER_MINUTE=0.006

# ── Rinkel ───────────────────────────────────────────────────────────────────
RINKEL_WEBHOOK_SECRET=your-webhook-secret

# ── Export ───────────────────────────────────────────────────────────────────
EXPORT_DIR=/data/exports
