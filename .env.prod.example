# ══════════════════════════════════════════════════════════════════════════════
# .env.prod — Production environment variables
#
# SECURITY: Never commit this file. Add to .gitignore.
# Copy from .env.prod.example and fill in real values before deploying.
# Managed on VPS at /var/rinkel/.env.prod (chmod 600, owned by deploy user)
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=rinkel-auditor
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=2
# Production CORS: restrict to your actual domains
CORS_ORIGINS=https://api.yourdomain.nl,https://app.yourdomain.nl

# ── Supabase (cloud — no local postgres needed in production) ─────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Direct Supabase PostgreSQL connection string (use connection pooling URL)
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── Local PostgreSQL (if NOT using Supabase cloud) ───────────────────────────
# Uncomment and configure if running local postgres container
# POSTGRES_DB=rinkel
# POSTGRES_USER=rinkel_user
# POSTGRES_PASSWORD=change-me-to-a-strong-password-min-32-chars
# DATABASE_URL=postgresql+asyncpg://rinkel_user:change-me@postgres:5432/rinkel

# ── Google Drive ──────────────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
# Path inside container — mounted from host credentials dir
GOOGLE_SERVICE_ACCOUNT_FILE=/data/credentials/service-account.json
# Comma-separated emails to auto-share uploaded recordings
GOOGLE_DRIVE_SHARE_WITH=team@company.nl

# ── Audio Processing ──────────────────────────────────────────────────────────
AUDIO_TEMP_DIR=/data/audio-temp
AUDIO_DOWNLOAD_TIMEOUT=120
AUDIO_MAX_FILE_SIZE_MB=500
AUDIO_RETRY_MAX_ATTEMPTS=3
AUDIO_RETRY_BASE_DELAY=2.0
AUDIO_CLEANUP_AFTER_UPLOAD=true

# ── Whisper / OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...your-production-key...
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=nl
WHISPER_RESPONSE_FORMAT=verbose_json
WHISPER_TEMPERATURE=0.0
WHISPER_MAX_FILE_SIZE_MB=25
WHISPER_CHUNK_DURATION_MINUTES=10
WHISPER_RETRY_MAX_ATTEMPTS=3
WHISPER_RETRY_BASE_DELAY=3.0
WHISPER_COST_PER_MINUTE=0.006

# ── Rinkel ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
RINKEL_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# ── Export ────────────────────────────────────────────────────────────────────
EXPORT_DIR=/data/exports
EXPORT_BATCH_SIZE=100
EXPORT_MAX_RECORDS=50000
EXPORT_RETENTION_DAYS=30

# ── Hosting ───────────────────────────────────────────────────────────────────
# Host directory binds for docker-compose.prod.yml volumes
EXPORT_HOST_DIR=/var/rinkel/exports
LOG_HOST_DIR=/var/log/rinkel
NGINX_LOG_DIR=/var/log/nginx/rinkel
CREDENTIALS_DIR=/var/rinkel/credentials
